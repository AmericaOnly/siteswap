# Prefer a backend proxy in production. Example:
# VITE_ZEROX_PROXY_URL=https://swap-api.yourdomain.com
VITE_ZEROX_PROXY_URL=

# Only needed if you are calling 0x directly from the browser.
VITE_ZEROX_API_KEY=your-0x-api-key
VITE_ZEROX_API_BASE_URL=https://api.0x.org

# Optional: affiliate fee configuration for 0x quote requests.
# Example: 50 = 0.50%
VITE_ZEROX_FEE_BPS=
VITE_ZEROX_FEE_RECIPIENT=

# Optional: defaults to the sell token if omitted.
VITE_ZEROX_FEE_TOKEN=
